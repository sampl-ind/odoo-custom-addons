<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_rk_rc_agreement_list" model="ir.ui.view">
        <field name="name">rk.rc.agreement.list</field>
        <field name="model">rk.rc.agreement</field>
        <field name="arch" type="xml">
            <list string="Rate Contracts"
                  decoration-danger="status == 'expired'"
                  decoration-warning="rc_validity_date and rc_validity_date &lt; (context_today() + relativedelta(days=30))">
                <field name="rc_number"/>
                <field name="item_code"/>
                <field name="product_id"/>
                <field name="brand_name"/>
                <field name="vendor_id"/>
                <field name="institution_ids" widget="many2many_tags"/>
                <field name="rate_per_unit"/>
                <field name="margin_percent" string="Margin%"/>
                <field name="commission_per_unit"/>
                <field name="claim_free_days"/>
                <field name="rc_validity_date"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'expired'"/>
                <field name="po_count" string="POs"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_rk_rc_agreement_form" model="ir.ui.view">
        <field name="name">rk.rc.agreement.form</field>
        <field name="model">rk.rc.agreement</field>
        <field name="arch" type="xml">
            <form string="Rate Contract">
                <header>
                    <button name="action_view_pos" type="object"
                            string="View POs" class="btn-secondary"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="active,expired,suspended"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_pos" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="po_count" widget="statinfo" string="POs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="rc_number" string="RC Number"/>
                        <h1><field name="rc_number" placeholder="e.g. 169"/></h1>
                        <h2><field name="brand_name" placeholder="Brand name e.g. Prospan Syrup"/></h2>
                    </div>

                    <group>
                        <group string="Product">
                            <field name="product_id"/>
                            <field name="item_code"/>
                        </group>
                        <group string="Parties">
                            <field name="vendor_id"/>
                            <field name="institution_ids" widget="many2many_tags"/>
                        </group>
                    </group>

                    <group>
                        <group string="Pricing">
                            <field name="rate_per_unit"/>
                            <field name="gst_percent"/>
                            <field name="margin_percent"/>
                            <field name="commission_per_unit" readonly="1"/>
                        </group>
                        <group string="Validity">
                            <field name="rc_validity_date"/>
                            <field name="agreement_validity_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Claim / Payment Terms">
                            <group>
                                <group>
                                    <field name="claim_free_days"/>
                                    <field name="claim_penalty_percent_per_week"/>
                                    <field name="claim_terms_note" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Supply / Penalty Terms">
                            <group>
                                <group>
                                    <field name="supply_days_normal"/>
                                    <field name="supply_days_extension"/>
                                    <field name="supply_penalty_percent_per_week"/>
                                    <field name="supply_penalty_max_percent"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search -->
    <record id="view_rk_rc_agreement_search" model="ir.ui.view">
        <field name="name">rk.rc.agreement.search</field>
        <field name="model">rk.rc.agreement</field>
        <field name="arch" type="xml">
            <search>
                <field name="rc_number"/>
                <field name="product_id"/>
                <field name="vendor_id"/>
                <field name="brand_name"/>
                <field name="item_code"/>
                <filter string="Active" name="active" domain="[('status','=','active')]"/>
                <filter string="Expired" name="expired" domain="[('status','=','expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vendor" name="group_vendor" context="{'group_by': 'vendor_id'}"/>
                    <filter string="RC Number" name="group_rc" context="{'group_by': 'rc_number'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_rk_rc_agreement" model="ir.actions.act_window">
        <field name="name">Rate Contracts</field>
        <field name="res_model">rk.rc.agreement</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_rk_rc_agreement_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
